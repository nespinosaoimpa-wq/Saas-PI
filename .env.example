# ==========================================
# VARIABLES DE ENTORNO — PIRIPI PRO
# ==========================================
# 1. Copia este archivo y renómbralo a ".env.local"
# 2. Pega aquí los valores de tu proyecto de Supabase
#    (Se encuentran en Project Settings -> API)

# Supabase
VITE_SUPABASE_URL=https://TU_PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=TU_ANON_KEY_LARGA

# Google Sheets Backup Webhook (Apps Script Web App URL)
VITE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/TU_SCRIPT_ID/exec
